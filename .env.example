# Server
PORT=8004

# gRPC
GRPC_PORT=50051

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=agent_skills
DB_SSL=false
DB_LOGGING=true
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ChromaDB (optional)
CHROMADB_URL=http://localhost:8000

# Rules Path
RULES_PATH=./src/rules

# BM25 Configuration
BM25_K1=1.5
BM25_B=0.75

# CORS
CORS_ORIGIN=*
